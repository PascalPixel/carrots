{
  "name": "carrots",
  "version": "1.3.0",
  "description": "Lightweight update server for Electron apps",
  "repository": "PascalPixel/carrots",
  "license": "MIT",
  "type": "module",
  "main": "lib/index.ts",
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --config .prettierrc.json -c ./**/*.ts && eslint . && tsc --noEmit",
    "format": "prettier --config .prettierrc.json -w ./**/*.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "find-my-way": "^9.6.0",
    "semver": "^7.8.4"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "async-listen": "^3.1.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
